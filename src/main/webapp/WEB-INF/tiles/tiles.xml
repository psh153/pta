<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE tiles-definitions PUBLIC
 "-//Apache Software Foundation//DTD Tiles Configuration 3.0//EN"
 "http://tiles.apache.org/dtds/tiles-config_3_0.dtd">

<tiles-definitions>

    <!-- 기본 레이아웃 -->
    <definition name="layout" template="/WEB-INF/views/layout.jsp" />

    
    <definition name="program" extends="layout">
        <put-attribute name="body"/>
    </definition>
    
    <definition name="program.login" extends="layout">
        <put-attribute name="body" value="/WEB-INF/views/login.jsp"/>
    </definition>
    
    <definition name="program.main" extends="layout">
        <put-attribute name="body" value="/WEB-INF/views/main.jsp"/>
    </definition>
    
    <definition name="program.detail" extends="layout">
    		<put-attribute name="sidebar" value="/WEB-INF/views/main.jsp"/>
        <put-attribute name="body" value="/WEB-INF/views/program/detail.jsp"/>
    </definition>

</tiles-definitions>
